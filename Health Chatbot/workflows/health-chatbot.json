    {
      "parameters": {
        "jsCode": "const text = $json.message.text.replace(/^\\/log\\s*/, \"\");\n// Extract text (meal) and number (calories), ignoring trailing spaces\nconst match = text.match(/(.+?)\\s+(\\d+)\\s*$/);\n\nif (match) {\n  return [{\n    json: {\n      userId: String($json.message.from.id),\n      chatId: String($json.message.chat.id),\n      meal: match[1].trim(),\n      calories: parseInt(match[2], 10),\n      valid: true\n    }\n  }];\n} else {\n  return [{\n    json: { valid: false, chatId: String($json.message.chat.id) }\n  }];\n}"
      },
      "id": "a9d03820-d19a-43fa-8d87-873553e69f02",
